// src/main/ets/utils/LoginStateManager.ets
import preferences from '@ohos.data.preferences';
import common from '@ohos.app.ability.common';
import { UserInfo, UpdateUserParams } from '../model/UserModel';

export class LoginStateManager {
  private static readonly PREF_NAME = 'my_app_prefs';
  private static readonly KEY_LOGIN = 'is_logged_in';
  private static readonly KEY_ACCESS_TOKEN = 'access_token';
  private static readonly KEY_USER_NAME = 'user_nickname';
  private static readonly KEY_USER_AVATAR = 'user_avatar';
  private static readonly KEY_USER_GENDER = 'user_gender';

  private static context: common.UIAbilityContext;

  static setContext(context: common.UIAbilityContext) {
    LoginStateManager.context = context;
  }

  private static async getPref(): Promise<preferences.Preferences> {
    if (!LoginStateManager.context) throw new Error("Context is null");
    return await preferences.getPreferences(LoginStateManager.context, LoginStateManager.PREF_NAME);
  }

  static async getToken(): Promise<string> {
    try {
      const pref = await LoginStateManager.getPref();
      return await pref.get(LoginStateManager.KEY_ACCESS_TOKEN, '') as string;
    } catch (e) { return ''; }
  }

  static async login(accessToken: string): Promise<void> {
    try {
      const pref = await LoginStateManager.getPref();
      await pref.put(LoginStateManager.KEY_LOGIN, true);
      await pref.put(LoginStateManager.KEY_ACCESS_TOKEN, accessToken);
      await pref.flush();
      AppStorage.setOrCreate('isLoggedIn', true);
    } catch (e) {}
  }

  static async saveUserInfo(info: UserInfo): Promise<void> {
    try {
      const pref = await LoginStateManager.getPref();

      let nameStr = (info.name && info.name.length > 0) ? info.name : (info.username || '大麦用户');
      let avatarStr = info.image || info.avatar || '';
      let genderVal = info.gender !== undefined ? Number(info.gender) : 0;

      await pref.put(LoginStateManager.KEY_USER_NAME, nameStr);
      await pref.put(LoginStateManager.KEY_USER_AVATAR, avatarStr);
      await pref.put(LoginStateManager.KEY_USER_GENDER, genderVal);
      await pref.flush();

      AppStorage.setOrCreate('user_nickname', nameStr);
      AppStorage.setOrCreate('user_avatar', avatarStr);

      let genderText = '保密';
      if (genderVal === 1) genderText = '男';
      if (genderVal === 2) genderText = '女';
      AppStorage.setOrCreate('user_gender_text', genderText);
    } catch (e) {}
  }

  // 【乐观更新】瞬间修改本地缓存和 UI
  static async updateLocalUserInfo(params: UpdateUserParams): Promise<void> {
    try {
      const pref = await LoginStateManager.getPref();

      if (params.name !== undefined) {
        AppStorage.setOrCreate('user_nickname', params.name);
        await pref.put(LoginStateManager.KEY_USER_NAME, params.name);
      }

      let newAvatar = params.image || params.avatar;
      if (newAvatar !== undefined) {
        AppStorage.setOrCreate('user_avatar', newAvatar);
        await pref.put(LoginStateManager.KEY_USER_AVATAR, newAvatar);
      }

      if (params.gender !== undefined) {
        let genderText = '保密';
        if (params.gender === 1) genderText = '男';
        if (params.gender === 2) genderText = '女';
        AppStorage.setOrCreate('user_gender_text', genderText);
        await pref.put(LoginStateManager.KEY_USER_GENDER, params.gender);
      }

      await pref.flush();
    } catch (e) {}
  }

  static async logout(): Promise<void> {
    try {
      const pref = await LoginStateManager.getPref();
      await pref.put(LoginStateManager.KEY_LOGIN, false);
      await pref.put(LoginStateManager.KEY_ACCESS_TOKEN, '');
      await pref.put(LoginStateManager.KEY_USER_NAME, '');
      await pref.put(LoginStateManager.KEY_USER_AVATAR, '');
      await pref.flush();

      AppStorage.setOrCreate('isLoggedIn', false);
      AppStorage.setOrCreate('user_nickname', '点击登录');
      AppStorage.setOrCreate('user_avatar', '');
      AppStorage.setOrCreate('user_gender_text', '');
    } catch (e) {}
  }

  static async initLoginStatus(): Promise<void> {
    try {
      const pref = await LoginStateManager.getPref();
      const isLogin = await pref.get(LoginStateManager.KEY_LOGIN, false) as boolean;
      const name = await pref.get(LoginStateManager.KEY_USER_NAME, '麦子cqdu1') as string;
      const avatar = await pref.get(LoginStateManager.KEY_USER_AVATAR, '') as string;
      const gender = await pref.get(LoginStateManager.KEY_USER_GENDER, 0) as number;

      AppStorage.setOrCreate('isLoggedIn', isLogin);
      AppStorage.setOrCreate('user_nickname', name);
      AppStorage.setOrCreate('user_avatar', avatar);

      let genderText = '保密';
      if (gender === 1) genderText = '男';
      if (gender === 2) genderText = '女';
      AppStorage.setOrCreate('user_gender_text', genderText);
    } catch (err) { AppStorage.setOrCreate('isLoggedIn', false); }
  }

  static isLoggedIn(): boolean {
    return AppStorage.get<boolean>('isLoggedIn') || false;
  }
}
