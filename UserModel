// src/main/ets/model/UserModel.ets

export interface LoginRequest {
  account?: string;
  password?: string;
  type?: number;
  email?: string;
  code?: string;
  name?: string;
  image?: string;
}

export interface UserInfo {
  id?: string | number;
  name?: string;
  username?: string;
  avatar?: string;
  image?: string;
  gender?: number;
}

export interface UpdateUserParams {
  name?: string;
  avatar?: string;
  image?: string;
  gender?: number;
}

export interface AddAddressRequest {
  province: string;
  city: string;
  district: string;
  detailedAddress: string;
  isDefault: boolean;
}

export interface LoginData {
  access_token: string;
  refresh_token?: string;
  token?: string;
}

export class LogoutParams {
  access_token: string = '';
  refresh_token: string = '';
}

export class ImageBody {
  image?: string = undefined;
}

export interface UploadResponse {
  code: number;
  msg: string;
  data: string;
}

// --- 演出列表相关 ---

export interface ShowItem {
  id: string;
  name: string;
  categoryName?: string;
  price?: number;
  minPrice?: number;
  cover?: string;
  // 兼容不同字段名
  title?: string;
  image?: string;
  sortName?: string;
}

// 【修复】定义 data 内部的对象结构
export interface ShowListData {
  total: number;
  list: ShowItem[];
}

// 【修复】data 类型明确为联合类型，不再使用 unknown
export interface ShowListResponse {
  code: number;
  msg: string;
  data: ShowListData | ShowItem[];
}

// --- 演出详情相关 ---

export interface Actor {
  id: number;
  showId: number;
  name: string;
}

export interface Session {
  id: number;
  showId: number;
  price: number;
  startTime: string;
  duration?: number;
  hasStock: boolean;
}

export interface ShowDetailData {
  id: number;
  title: string;
  image: string;
  province: string;
  city: string;
  district: string;
  venueName: string;
  detailAddress: string;
  fullAddress: string;
  sortId: number;
  sortName: string;
  actors: Actor[];
  sessions: Session[];
  hasStock: boolean;
  issued: boolean;
}

export interface ShowDetailResponse {
  code: number;
  msg: string | null;
  data: ShowDetailData;
}
