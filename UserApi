      const response = await httpRequest.request(url, {
        method: http.RequestMethod.GET,
        header: { 'Content-Type': 'application/json', 'token': token }
      });
      if (response.responseCode === 200) {
        const resObj = JSON.parse(response.result as string) as AddressResponse;
        if (resObj.code === 1 && resObj.data && resObj.data.records) {
          return resObj.data.records;
        }
      }
    } catch (e) {} finally { httpRequest.destroy(); }
    return[];
  }

  // 13. 修改地址 (PUT)
  static async updateAddress(addressId: number, data: Partial<AddressItem>): Promise<boolean> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();
    try {
      const response = await httpRequest.request(`${BASE_URL}/user/user/map/${addressId}`, {
        method: http.RequestMethod.PUT,
        header: { 'Content-Type': 'application/json', 'token': token },
        extraData: data
      });
      return response.responseCode === 200;
    } catch (e) { return false; } finally { httpRequest.destroy(); }
  }


  static async addAddress(params: AddressItem): Promise<boolean> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();

    try {
      const response = await httpRequest.request(`${BASE_URL}/user/user/map`, {
        method: http.RequestMethod.POST,
        header: {
          'Content-Type': 'application/json',
          'token': token
        },
        extraData: params
      });

      if (response.responseCode === 200) {
        const resObj = JSON.parse(response.result as string) as Record<string, Object>;
        return resObj['code'] === 1;
      }
      return false;
    } catch (e) {
      console.error("UserApi: addAddress Error", JSON.stringify(e));
      return false;
    } finally {
      httpRequest.destroy();
    }
  }
}
