import http from '@ohos.net.http';
import { LoginRequest, UserInfo, UpdateUserParams, LoginData, LogoutParams, AddAddressRequest, ImageBody } from '../model/UserModel';
import { LoginStateManager } from '../utils/LoginStateManager';
import { promptAction } from '@kit.ArkUI';

const BASE_URL = 'http://8.136.46.14:8080';

interface ResponseWrapper {
  code?: number;
  msg?: string;
  data?: ResponseContent;
  access_token?: string;
  id?: string | number;
  name?: string;
  username?: string;
  avatar?: string;
  image?: string;
  gender?: number;
}
interface ResponseContent extends UserInfo, LoginData {}

export class UserApi {

  // 1. 登录
  static async login(params: LoginRequest): Promise<boolean> {
    const httpRequest = http.createHttp();
    try {
      const response = await httpRequest.request(`${BASE_URL}/user/login`, {
        method: http.RequestMethod.POST,
        header: { 'Content-Type': 'application/json' },
        extraData: params
      });

      if (response.responseCode === 200) {
        const resObj = JSON.parse(response.result as string) as ResponseWrapper;
        let token = resObj.data ? (resObj.data.token || resObj.data.access_token) : resObj.access_token;

        if (token && token.length > 0) {
          await LoginStateManager.login(token);
          // 登录成功 -> 拉取最新数据
          await UserApi.getUserInfo();
          promptAction.showToast({ message: '登录成功' });
          return true;
        }
      }
      return false;
    } catch (err) { return false; } finally { httpRequest.destroy(); }
  }

  // 2. 获取用户信息
  static async getUserInfo(): Promise<void> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();
    if (token.length === 0) return;

    try {
      const response = await httpRequest.request(`${BASE_URL}/user/user`, {
        method: http.RequestMethod.GET,
        header: { 'Content-Type': 'application/json', 'token': token }
      });

      if (response.responseCode === 200) {
        const resObj = JSON.parse(response.result as string) as ResponseWrapper;
        let info: UserInfo | undefined = undefined;

        if (resObj.data) {
          info = resObj.data as UserInfo;
        } else if (resObj.id || resObj.username || resObj.name) {
          info = {
            id: resObj.id, name: resObj.name, username: resObj.username,
            image: resObj.image || resObj.avatar, gender: resObj.gender
          };
        }

        // 拿到最新数据 -> 存入本地 -> 刷新 UI
        if (info) await LoginStateManager.saveUserInfo(info);
      }
    } catch (e) {} finally { httpRequest.destroy(); }
  }

  // 3. 【核心修复】修改用户信息 (双重传参策略)
  static async updateUserInfo(params: UpdateUserParams): Promise<boolean> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();
    if (token.length === 0) return false;

    // 策略 A: 拼接到 URL (Query Params)
    let urlParams: string[] = [];
    if (params.name !== undefined) urlParams.push(`name=${encodeURIComponent(params.name)}`);
    if (params.gender !== undefined) urlParams.push(`gender=${params.gender}`);
    let query = urlParams.length > 0 ? `?${urlParams.join('&')}` : '';
    const finalUrl = `${BASE_URL}/user/user${query}`;

    // 策略 B: 放入 Body (JSON)
    // 我们把 name, gender, image 全部放进 Body，防止后端只读 Body 忽略 URL
    let bodyData: Record<string, Object> = {};
    if (params.image) bodyData['image'] = params.image;
    else if (params.avatar) bodyData['image'] = params.avatar;

    if (params.name !== undefined) bodyData['name'] = params.name;
    if (params.gender !== undefined) bodyData['gender'] = params.gender;

    console.info(`UserApi: 提交修改 -> URL: ${finalUrl}, Body: ${JSON.stringify(bodyData)}`);

    try {
      const response = await httpRequest.request(finalUrl, {
        method: http.RequestMethod.PUT,
        header: { 'Content-Type': 'application/json', 'token': token },
        extraData: bodyData // 发送全量数据
      });

      console.info(`UserApi: 修改响应码 -> ${response.responseCode}`);

      if (response.responseCode === 200) {
        // 修改成功 -> 立刻拉取最新数据
        // 只有拉取到了，UI 才会变，确保持久化和显示的一致性
        await UserApi.getUserInfo();

        promptAction.showToast({ message: '修改成功' });
        return true;
      }
      return false;
    } catch (e) { return false; } finally { httpRequest.destroy(); }
  }

  // 4. 添加地址
  static async addAddress(addr: AddAddressRequest): Promise<boolean> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();
    if (token.length == 0) return false;
    try {
      const res = await httpRequest.request(`${BASE_URL}/user/user/map`, {
        method: http.RequestMethod.POST,
        header: { 'Content-Type': 'application/json', 'token': token },
        extraData: addr
      });
      if (res.responseCode === 200) {
        promptAction.showToast({ message: '地址保存成功' });
        return true;
      }
      return false;
    } catch (e) { return false; } finally { httpRequest.destroy(); }
  }

  // 5. 退出登录
  static async logout(): Promise<void> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();
    if (token.length > 0) {
      try {
        let logoutBody = new LogoutParams();
        logoutBody.access_token = token;
        await httpRequest.request(`${BASE_URL}/user/login/logout`, {
          method: http.RequestMethod.POST,
          header: { 'Content-Type': 'application/json', 'token': token },
          extraData: logoutBody
        });
      } catch (e) {}
    }
    await LoginStateManager.logout();
    promptAction.showToast({ message: '已退出登录' });
  }
}
