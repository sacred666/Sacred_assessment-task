import http from '@ohos.net.http';
import {
  LoginRequest, UserInfo, UpdateUserParams, LoginData, LogoutParams, AddAddressRequest, ImageBody, UploadResponse,
  ShowItem, ShowListResponse, ShowDetailResponse, ShowDetailData,
  BuyTicketRequest, BuyTicketResponse,
  OrderItem, OrderListResponse,
  AddressItem, AddressResponse
} from '../model/UserModel';
import { LoginStateManager } from '../utils/LoginStateManager';
import { promptAction } from '@kit.ArkUI';
import fs from '@ohos.file.fs';
import util from '@ohos.util';
import { common } from '@kit.AbilityKit';

const BASE_URL = 'http://8.136.46.14:8080';

// ---------------- 接口定义 ----------------
interface BackendData {
  token?: string | null;
  access_token?: string | null;
  id?: string | number;
  name?: string;
  username?: string;
  avatar?: string;
  image?: string;
  gender?: number;
}

interface ResponseWrapper {
  code?: number;
  msg?: string;
  data?: BackendData | null; // 【修复1】允许 data 为 null
  access_token?: string | null;
  token?: string | null;     // 【修复2】允许 token 为 null
  id?: string | number;
  name?: string;
  username?: string;
  avatar?: string;
  image?: string;
  gender?: number;
}

interface OrderFlexData {
  list?: OrderItem[];
  records?: OrderItem[];
  rows?: OrderItem[];
  data?: OrderItem[];
}
interface OrderFlexResponse {
  code?: number;
  msg?: string;
  data?: OrderFlexData | OrderItem[];
}

interface ShowFlexData {
  list?: ShowItem[];
  records?: ShowItem[];
  rows?: ShowItem[];
  data?: ShowItem[];
}
interface ShowFlexResponse {
  code?: number;
  msg?: string;
  data?: ShowFlexData | ShowItem[];
}

// ---------------- API 类 ----------------
export class UserApi {

  // 1. 登录与注册共用接口
  static async login(params: LoginRequest): Promise<boolean> {
    const httpRequest = http.createHttp();
    const jsonStr = JSON.stringify(params);
    console.info("🚀 [发送给后端的数据]：", jsonStr);

    try {
      const localToken = await LoginStateManager.getToken();
      let headers: Record<string, string> = { 'Content-Type': 'application/json' };
      if (localToken) headers['token'] = localToken;

      const response = await httpRequest.request(`${BASE_URL}/user/login`, {
        method: http.RequestMethod.POST,
        header: headers,
        extraData: jsonStr,
        readTimeout: 10000,
        connectTimeout: 10000
      });

      console.info(`==== 后端返回 HTTP 状态码: ${response.responseCode} ====`);
      console.info("==== 后端返回完整内容 ====", response.result);

      if (response.responseCode === 200) {
        let resObj: ResponseWrapper;
        try {
          resObj = JSON.parse(response.result as string) as ResponseWrapper;
        } catch (e) {
          promptAction.showToast({ message: '数据解析失败，请检查后端服务' });
          return false;
        }

        // 以 code === 1 作为真正的成功标准
        if (resObj.code === 1) {

          // 【核心修复】极其安全的 token 获取方式，彻底杜绝 null.length 崩溃
          let token: string = '';
          if (resObj.data && typeof resObj.data === 'object') {
            token = resObj.data.token || resObj.data.access_token || '';
          }
          if (!token) {
            token = resObj.token || resObj.access_token || '';
          }

          // 只有当 token 是有效字符串时，才执行登录状态保存
          if (typeof token === 'string' && token.length > 0) {
            await LoginStateManager.login(token);
            await UserApi.getUserInfo();
          } else {
            console.info("UserApi: 未获取到 token，通常是因为注册成功。");
          }

          return true; // 无论有没有 token，只要 code 是 1 就代表业务成功！
        } else {
          promptAction.showToast({ message: resObj.msg || '操作失败' });
          return false;
        }
      } else {
        promptAction.showToast({ message: `后端接口异常(HTTP ${response.responseCode})` });
        return false;
      }
    } catch (err) {
      let errMsg = err instanceof Error ? err.message : JSON.stringify(err);
      console.error("UserApi login 底层错误:", errMsg);
      promptAction.showToast({ message: `请求出错: ${errMsg}` });
      return false;
    } finally {
      httpRequest.destroy();
    }
  }

  // 2. 获取用户信息
  static async getUserInfo(): Promise<void> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();
    if (token.length === 0) return;

    try {
      const response = await httpRequest.request(`${BASE_URL}/user/user`, {
        method: http.RequestMethod.GET,
        header: { 'Content-Type': 'application/json', 'token': token }
      });

      if (response.responseCode === 200) {
        const resObj = JSON.parse(response.result as string) as ResponseWrapper;
        let info: UserInfo | undefined = undefined;

        if (resObj.data !== undefined && resObj.data !== null) {
          info = {
            id: resObj.data.id !== undefined ? resObj.data.id : '',
            name: resObj.data.name,
            username: resObj.data.username,
            avatar: resObj.data.avatar,
            image: resObj.data.image,
            gender: resObj.data.gender
          };
        } else if (resObj.id !== undefined) {
          info = {
            id: resObj.id,
            name: resObj.name,
            username: resObj.username,
            avatar: resObj.avatar,
            image: resObj.image,
            gender: resObj.gender
          };
        }

        if (info !== undefined) {
          await LoginStateManager.saveUserInfo(info);
        }
      }
    } catch (e) {
    } finally {
      httpRequest.destroy();
    }
  }

  // 3. 修改用户信息
  static async updateUserInfo(params: UpdateUserParams): Promise<boolean> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();
    if (token.length === 0) return false;

    let urlParams: string[] =[];
    if (params.name !== undefined) {
      urlParams.push(`name=${encodeURIComponent(params.name)}`);
    }
    if (params.gender !== undefined) {
      urlParams.push(`gender=${params.gender}`);
    }
    let queryString = '';
    if (urlParams.length > 0) {
      queryString = `?${urlParams.join('&')}`;
    }
    const finalUrl = `${BASE_URL}/user/user${queryString}`;

    let bodyData: Record<string, Object> = {};
    if (params.image !== undefined) bodyData['image'] = params.image;
    else if (params.avatar !== undefined) bodyData['image'] = params.avatar;
    if (params.name !== undefined) bodyData['name'] = params.name;
    if (params.gender !== undefined) bodyData['gender'] = params.gender;

    try {
      const response = await httpRequest.request(finalUrl, {
        method: http.RequestMethod.PUT,
        header: { 'Content-Type': 'application/json', 'token': token },
        extraData: bodyData
      });

      if (response.responseCode === 200) {
        await UserApi.getUserInfo();
        promptAction.showToast({ message: '修改成功' });
        return true;
      }
      return false;
    } catch (e) {
      return false;
    } finally {
      httpRequest.destroy();
    }
  }

  // 4. 上传图片
  static async uploadImage(context: common.UIAbilityContext, fileUri: string): Promise<string> {
    const httpRequest = http.createHttp();
    try {
      const file = fs.openSync(fileUri, fs.OpenMode.READ_ONLY);
      const fileStat = fs.statSync(file.fd);
      const buf = new ArrayBuffer(fileStat.size);
      fs.readSync(file.fd, buf);
      fs.closeSync(file);

      const boundary = '----WebKitFormBoundary' + new Date().getTime();
      const head =
        `--${boundary}\r\nContent-Disposition: form-data; name="file"; filename="avatar.jpg"\r\nContent-Type: image/jpeg\r\n\r\n`;
      const tail = `\r\n--${boundary}--\r\n`;

      const textEncoder = new util.TextEncoder();
      const headBuf = textEncoder.encodeInto(head);
      const tailBuf = textEncoder.encodeInto(tail);
      const totalSize = headBuf.length + buf.byteLength + tailBuf.length;
      const fullBuf = new Uint8Array(totalSize);
      fullBuf.set(headBuf, 0);
      fullBuf.set(new Uint8Array(buf), headBuf.length);
      fullBuf.set(tailBuf, headBuf.length + buf.byteLength);

      const response = await httpRequest.request(`${BASE_URL}/user/upload`, {
        method: http.RequestMethod.POST,
        header: { 'Content-Type': `multipart/form-data; boundary=${boundary}` },
        extraData: fullBuf.buffer
      });

      if (response.responseCode === 200) {
        const resObj = JSON.parse(response.result as string) as UploadResponse;
        if (resObj.code === 1 && resObj.data) {
          return resObj.data;
        }
      }
      return '';
    } catch (e) {
      return '';
    } finally {
      httpRequest.destroy();
    }
  }

  // 5. 添加地址 (旧版)
  static async addAddress1(addr: AddAddressRequest): Promise<boolean> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();
    if (token.length === 0) return false;
    try {
