import http from '@ohos.net.http';
import {
  LoginRequest, UserInfo, UpdateUserParams, LoginData, LogoutParams, AddAddressRequest, ImageBody, UploadResponse,
  ShowItem, ShowListResponse, ShowDetailResponse, ShowDetailData,
  BuyTicketRequest, BuyTicketResponse,
  OrderItem, OrderListResponse // 确保引入了 OrderItem
} from '../model/UserModel';
import { LoginStateManager } from '../utils/LoginStateManager';
import { promptAction } from '@kit.ArkUI';
import fs from '@ohos.file.fs';
import util from '@ohos.util';
import { common } from '@kit.AbilityKit';

const BASE_URL = 'http://8.136.46.14:8080';

// ================== 接口定义区域 ==================
interface BackendData {
  token?: string;
  access_token?: string;
  id?: string | number;
  name?: string;
  username?: string;
  avatar?: string;
  image?: string;
  gender?: number;
}

interface ResponseWrapper {
  code?: number;
  msg?: string;
  data?: BackendData;
  access_token?: string;
  token?: string;
  id?: string | number;
  name?: string;
  username?: string;
  avatar?: string;
  image?: string;
  gender?: number;
}

// 【新增】用于暴力兼容后端订单分页接口可能出现的各种 JSON 结构
interface FlexData {
  list?: OrderItem[];
  records?: OrderItem[];
  rows?: OrderItem[];
  data?: OrderItem[];
}

interface FlexResponse {
  code?: number;
  msg?: string;
  data?: FlexData | OrderItem[];
}


// ================== API 类定义 ==================
export class UserApi {
  // 1. 登录
  static async login(params: LoginRequest): Promise<boolean> {
    const httpRequest = http.createHttp();
    try {
      const response = await httpRequest.request(`${BASE_URL}/user/login`, {
        method: http.RequestMethod.POST,
        header: { 'Content-Type': 'application/json' },
        extraData: params
      });

      if (response.responseCode === 200) {
        const resObj = JSON.parse(response.result as string) as ResponseWrapper;
        let token: string | undefined = undefined;

        if (resObj.data !== undefined) {
          token = resObj.data.token || resObj.data.access_token;
        } else {
          token = resObj.token || resObj.access_token;
        }

        if (token !== undefined && token.length > 0) {
          await LoginStateManager.login(token);
          // 登录成功 -> 拉取最新数据
          await UserApi.getUserInfo();
          promptAction.showToast({ message: '登录成功' });
          return true;
        } else {
          promptAction.showToast({ message: resObj.msg || '登录失败' });
        }
      }
      return false;
    } catch (err) {
      promptAction.showToast({ message: '网络请求失败' });
      return false;
    } finally {
      httpRequest.destroy();
    }
  }

  // 2. 获取用户信息
  static async getUserInfo(): Promise<void> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();
    if (token.length === 0) return;

    try {
      const response = await httpRequest.request(`${BASE_URL}/user/user`, {
        method: http.RequestMethod.GET,
        header: { 'Content-Type': 'application/json', 'token': token }
      });

      if (response.responseCode === 200) {
        const resObj = JSON.parse(response.result as string) as ResponseWrapper;
        let info: UserInfo | undefined = undefined;

        if (resObj.data !== undefined) {
          info = {
            id: resObj.data.id !== undefined ? resObj.data.id : '',
            name: resObj.data.name,
            username: resObj.data.username,
            avatar: resObj.data.avatar,
            image: resObj.data.image,
            gender: resObj.data.gender
          };
        } else if (resObj.id !== undefined) {
          info = {
            id: resObj.id,
            name: resObj.name,
            username: resObj.username,
            avatar: resObj.avatar,
            image: resObj.image,
            gender: resObj.gender
          };
        }

        if (info !== undefined) {
          // 这一步会将最新数据写入硬盘，并刷新 UI
          await LoginStateManager.saveUserInfo(info);
        }
      }
    } catch (e) {
    } finally {
      httpRequest.destroy();
    }
  }

  // 3. 【双重保险】修改用户信息
  static async updateUserInfo(params: UpdateUserParams): Promise<boolean> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();
    if (token.length === 0) return false;

    // --- 策略 A: 拼接到 URL (Query Params) ---
    let urlParams: string[] =[];
    if (params.name !== undefined) {
      urlParams.push(`name=${encodeURIComponent(params.name)}`);
    }
    if (params.gender !== undefined) {
      urlParams.push(`gender=${params.gender}`);
    }
    let queryString = '';
    if (urlParams.length > 0) {
      queryString = `?${urlParams.join('&')}`;
    }
    const finalUrl = `${BASE_URL}/user/user${queryString}`;

    // --- 策略 B: 放入 Body (JSON) ---
    let bodyData: Record<string, Object> = {};

    if (params.image !== undefined) bodyData['image'] = params.image; else if (params.avatar !==
      undefined) bodyData['image'] = params.avatar;

    if (params.name !== undefined) bodyData['name'] = params.name;
    if (params.gender !== undefined) bodyData['gender'] = params.gender;

    try {
      const response = await httpRequest.request(finalUrl, {
        method: http.RequestMethod.PUT,
        header: { 'Content-Type': 'application/json', 'token': token },
        extraData: bodyData // 发送全量数据
      });

      if (response.responseCode === 200) {
        // 修改成功后立即拉取最新数据
        await UserApi.getUserInfo();
        promptAction.showToast({ message: '修改成功' });
        return true;
      }
      return false;
    } catch (e) {
      return false;
    } finally {
      httpRequest.destroy();
    }
  }

  // 4. 上传图片
  static async uploadImage(context: common.UIAbilityContext, fileUri: string): Promise<string> {
    const httpRequest = http.createHttp();
    try {
      const file = fs.openSync(fileUri, fs.OpenMode.READ_ONLY);
      const fileStat = fs.statSync(file.fd);
      const buf = new ArrayBuffer(fileStat.size);
      fs.readSync(file.fd, buf);
      fs.closeSync(file);

      const boundary = '----WebKitFormBoundary' + new Date().getTime();
      const head =
        `--${boundary}\r\nContent-Disposition: form-data; name="file"; filename="avatar.jpg"\r\nContent-Type: image/jpeg\r\n\r\n`;
      const tail = `\r\n--${boundary}--\r\n`;

      const textEncoder = new util.TextEncoder();
      const headBuf = textEncoder.encodeInto(head);
      const tailBuf = textEncoder.encodeInto(tail);
      const totalSize = headBuf.length + buf.byteLength + tailBuf.length;
      const fullBuf = new Uint8Array(totalSize);
      fullBuf.set(headBuf, 0);
      fullBuf.set(new Uint8Array(buf), headBuf.length);
      fullBuf.set(tailBuf, headBuf.length + buf.byteLength);

      const response = await httpRequest.request(`${BASE_URL}/user/upload`, {
        method: http.RequestMethod.POST,
        header: { 'Content-Type': `multipart/form-data; boundary=${boundary}` },
        extraData: fullBuf.buffer
      });

      if (response.responseCode === 200) {
        const resObj = JSON.parse(response.result as string) as UploadResponse;
        if (resObj.code === 1 && resObj.data) {
          return resObj.data;
        }
      }
      return '';
    } catch (e) {
      return '';
    } finally {
      httpRequest.destroy();
    }
  }

  // 5. 添加地址
  static async addAddress(addr: AddAddressRequest): Promise<boolean> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();
    if (token.length === 0) return false;
    try {
      const res = await httpRequest.request(`${BASE_URL}/user/user/map`, {
        method: http.RequestMethod.POST,
        header: { 'Content-Type': 'application/json', 'token': token },
        extraData: addr
      });
      if (res.responseCode === 200) {
        promptAction.showToast({ message: '地址保存成功' });
        return true;
      }
      return false;
    } catch (e) {
      return false;
    } finally {
      httpRequest.destroy();
    }
  }

  // 6. 退出登录
  static async logout(): Promise<void> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();
    if (token.length > 0) {
      try {
        let logoutBody = new LogoutParams();
        logoutBody.access_token = token;
        await httpRequest.request(`${BASE_URL}/user/login/logout`, {
          method: http.RequestMethod.POST,
          header: { 'Content-Type': 'application/json', 'token': token },
          extraData: logoutBody
        });
      } catch (e) {
      }
    }
    await LoginStateManager.logout();
    promptAction.showToast({ message: '已退出登录' });
    httpRequest.destroy();
  }


  // 7. 获取首页演出列表
  static async getShowList(): Promise<ShowItem[]> {
    const httpRequest = http.createHttp();
    try {
      const url = `${BASE_URL}/user/show?page=1&pageSize=10&city=${encodeURIComponent('深圳市')}`;
      const response = await httpRequest.request(url, {
        method: http.RequestMethod.GET,
        header: { 'Content-Type': 'application/json' }
      });

      if (response.responseCode === 200) {
        const resObj = JSON.parse(response.result as string) as ShowListResponse;
        if (resObj.code === 1 && Array.isArray(resObj.data)) {
          return resObj.data;
        }
      }
    } catch (e) {
    } finally {
      httpRequest.destroy();
    }
    return[];
  }

  // 8. 获取详情
  static async getShowDetail(id: number): Promise<ShowDetailData | null> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();
    try {
      const url = `${BASE_URL}/user/show/detail?id=${id}`;
      const header: Record<string, string> = { 'Content-Type': 'application/json' };
      if (token) header['token'] = token;

      const response = await httpRequest.request(url, { method: http.RequestMethod.GET, header: header });
      if (response.responseCode === 200) {
        const resObj = JSON.parse(response.result as string) as ShowDetailResponse;
        if (resObj.code === 1 && resObj.data) {
          return resObj.data;
        }
      }
    } catch (e) {} finally { httpRequest.destroy(); }
    return null;
  }

  // 9. 抢票接口
  static async buyTicket(sessionId: number, quantity: number): Promise<boolean> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();

    if (!token || token.length === 0) {
      promptAction.showToast({ message: '请先登录' });
      return false;
    }

    try {
      const requestBody: BuyTicketRequest = {
        sessionId: sessionId,
        quantity: quantity
      };

      const response = await httpRequest.request(`${BASE_URL}/user/show/buy`, {
        method: http.RequestMethod.POST,
        header: {
          'Content-Type': 'application/json',
          'token': token
        },
        extraData: requestBody
      });

      if (response.responseCode === 200) {
        const resObj = JSON.parse(response.result as string) as BuyTicketResponse;
        if (resObj.code === 1) {
          promptAction.showToast({ message: '抢票成功！' });
          return true;
        } else {
          promptAction.showToast({ message: resObj.msg || '抢票失败' });
        }
      } else {
        promptAction.showToast({ message: `请求失败: ${response.responseCode}` });
      }
      return false;
    } catch (e) {
      promptAction.showToast({ message: '网络请求异常' });
      return false;
    } finally {
      httpRequest.destroy();
    }
  }

  // 10. 【终极兼容修复】获取订单列表
  static async getOrderList(page: number, pageSize: number = 10, status: number | null): Promise<OrderItem[]> {
    const httpRequest = http.createHttp();
    const token = await LoginStateManager.getToken();

    if (!token || token.length === 0) {
      console.info('UserApi: No token, return empty order list');
      return [];
    }

    try {
      let url = `${BASE_URL}/user/order?page=${page}&pageSize=${pageSize}`;

      // 注意：如果您后端的“全部订单”也必须传 orderStatus=0 或为空，请在这里调整
      // 目前逻辑：如果不等于 -1，才拼接到 url 里
      if (status !== null && status !== -1) {
        url += `&orderStatus=${status}`;
      }

      console.info(`UserApi: 请求订单 -> URL: ${url}`);

      const response = await httpRequest.request(url, {
        method: http.RequestMethod.GET,
        header: { 'Content-Type': 'application/json', 'token': token }
      });

      if (response.responseCode === 200) {
        // 打印原始字符串，如果在 Log 看到这里有真实数据，说明网路没问题
        console.info(`UserApi: 订单原始响应 -> ${response.result}`);

        // 利用 FlexResponse 兼容任意数据结构，不再出现 any 警告
        const resObj = JSON.parse(response.result as string) as FlexResponse;

        if (resObj.data) {
          // 场景 1: data 字段直接是一个数组 (后端直接返回数组)
          if (Array.isArray(resObj.data)) {
            return resObj.data as OrderItem[];
          }

          // 场景 2: data 是一个分页对象，里面可能是 list / records / rows 字段
          const pageObj = resObj.data as FlexData;
          if (pageObj.list && Array.isArray(pageObj.list)) return pageObj.list;
          if (pageObj.records && Array.isArray(pageObj.records)) return pageObj.records;
          if (pageObj.rows && Array.isArray(pageObj.rows)) return pageObj.rows;
          if (pageObj.data && Array.isArray(pageObj.data)) return pageObj.data;
        }
      }
    } catch (e) {
      console.error('UserApi: 订单请求失败', JSON.stringify(e));
    } finally {
      httpRequest.destroy();
    }
    return []
  }

}
