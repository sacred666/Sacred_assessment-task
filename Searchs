import { preferences } from '@kit.ArkData';
import { common } from "@kit.AbilityKit";
import { NavUtils } from "../utils/NavUtils";
import { UserApi } from "../api/UserApi";
import { promptAction } from '@kit.ArkUI';
import { ShowItem } from "../model/UserModel";

@Builder
export function SearchsBuilder() {
  Searchs()
}

@Component
export struct Searchs {
  @State historylist: string[] = []
  @State keywords: string = ""
  private prefs: preferences.Preferences | null = null;
  pathStack: NavPathStack = NavUtils.stack;

  async aboutToAppear() {
    try {
      const context = getContext(this) as common.UIAbilityContext;
      this.prefs = await preferences.getPreferences(context, 'search_history');
      const storedHistory: string = await this.prefs.get('history', '[]') as string;
      const parsedHistory: string[] = JSON.parse(storedHistory) as string[];
      if (Array.isArray(parsedHistory)) this.historylist = parsedHistory;
    } catch (error) {}
  }

  async saveSearchHistory(): Promise<void> {
    if (!this.prefs) return;
    try {
      await this.prefs.put('history', JSON.stringify(this.historylist));
      await this.prefs.flush();
    } catch (error) {}
  }

  async addSearchHistory(keyword: string): Promise<void> {
    if (!keyword.trim()) return;
    let newHistory: string[] = [...this.historylist];
    const index: number = newHistory.indexOf(keyword);
    if (index !== -1) newHistory.splice(index, 1);
    newHistory.unshift(keyword);
    if (newHistory.length > 50) newHistory = newHistory.slice(0, 50);
    this.historylist = newHistory;
    await this.saveSearchHistory();
  }

  async clearSearchHistory(): Promise<void> {
    this.historylist = [];
    await this.saveSearchHistory();
  }

  async doSearch(inputKeyword: string) {
    const kw = inputKeyword.trim();
    if (kw.length === 0) {
      promptAction.showToast({ message: '请输入搜索内容' });
      return;
    }

    // 1. 记录历史
    await this.addSearchHistory(kw);

    // 2. 调用接口
    const list = await UserApi.searchShow(kw);

    // 3. 判断结果
    if (list && list.length > 0) {
      // 【修复】构造强类型参数，解决 Object literal 报错
      let param: Record<string, Object> = {
        'keyword': kw,
        'cachedData': list
      };

      NavUtils.push("SearchResult", param);
      this.keywords = "";
    } else {
      promptAction.showToast({ message: '未找到相关演出' });
    }
  }

  build() {
    NavDestination() {
      Column() {
        Row() {
          Row() {
            Image($r("app.media.search")).padding({ left: 10 }).width(30)
            TextInput({
              placeholder: "2025 卓沅【KEY'S KEYS】巡回...",
              text: this.keywords // 【修复】移除 $$，改用 onChange 手动管理
            })
              .placeholderColor('#817D83')
              .onChange((value) => { this.keywords = value; })
              .onSubmit(() => { this.doSearch(this.keywords) })
              .fontColor('#151515')
              .layoutWeight(1)
              .backgroundColor(Color.Transparent)
              .margin({ right: 6 })
          }
          .layoutWeight(1)
          .backgroundColor("#f8ebfa")
          .border({ radius: 20 })
          Text("取消")
            .fontSize(16)
            .margin({ left: 15 })
            .onClick(() => { NavUtils.pop() })
        }
        .margin({ bottom: 30 })
        .width("100%")

        Row() {
          Text("搜索历史").fontSize(18).fontWeight(FontWeight.Bold).layoutWeight(1)
          Image($r("app.media.delete")).width(20).onClick(() => { this.clearSearchHistory(); })
        }.margin({ bottom: 20 }).width("100%")

        Flex({ wrap: FlexWrap.Wrap }) {
          ForEach(this.historylist, (item: string) => {
            Text(item)
              .backgroundColor("#f6f6f6")
              .fontSize(14)
              .padding({ left: 12, right: 12, top: 6, bottom: 6 })
              .border({ radius: 20 })
              .margin({ right: 10, bottom: 10 })
              .onClick(() => {
                this.keywords = item;
                this.doSearch(item);
              })
          }, (item: string) => item)
        }
      }
      .width("100%").height("100%").backgroundColor(Color.White)
      .padding({ right: 20, left: 20, top: 10, bottom: 20 })
      .expandSafeArea([SafeAreaType.SYSTEM], [SafeAreaEdge.TOP, SafeAreaEdge.BOTTOM])
    }
    .hideTitleBar(true)
  }
}
