// src/main/ets/utils/NavUtils.ets
export class NavUtils {
  // 全局唯一的路由栈实例
  static readonly stack: NavPathStack = new NavPathStack();

  // 【修复】增加 param 参数，默认为 null，解决 Searchs.ets 调用报错的问题
  static push(name: string, param: Object | null = null) {
    console.info(`NavUtils: push -> ${name}, param: ${JSON.stringify(param)}`);
    NavUtils.stack.pushPathByName(name, param);
  }

  static pop() {
    console.info(`NavUtils: pop`);
    NavUtils.stack.pop();
  }

  static replace(name: string, param: Object | null = null) {
    NavUtils.stack.replacePathByName(name, param, false);
  }

  static clear() {
    NavUtils.stack.clear();
  }
}
