import preferences from '@ohos.data.preferences';

const PREFERENCES_NAME = 'myAppPreferences';
const SEARCH_HISTORY_KEY = 'searchHistory';

class SearchHistoryManager {
  private preferences: preferences.Preferences | null = null;

  async initPreferences(context: Context): Promise<void> {
    try {
      this.preferences = await preferences.getPreferences(context, PREFERENCES_NAME);
    } catch (err) {
      console.error('SearchHistoryManager: Failed to initialize preferences, error: ' + err);
    }
  }

  async saveSearchHistory(history: string[]): Promise<void> {
    if (!this.preferences) {
      console.error('SearchHistoryManager: Preferences not initialized');
      return;
    }
    try {
      await this.preferences.put(SEARCH_HISTORY_KEY, JSON.stringify(history));
      await this.preferences.flush();
    } catch (err) {
      console.error('SearchHistoryManager: Failed to save search history, error: ' + err);
    }
  }

  async getSearchHistory(): Promise<string[]> {
    if (!this.preferences) {
      console.error('SearchHistoryManager: Preferences not initialized');
      return [];
    }
    try {
      const historyJson = await this.preferences.get(SEARCH_HISTORY_KEY, '[]');
      return JSON.parse(historyJson as string);
    } catch (err) {
      console.error('SearchHistoryManager: Failed to get search history, error: ' + err);
      return [];
    }
  }

  async clearSearchHistory(): Promise<void> {
    if (!this.preferences) {
      console.error('SearchHistoryManager: Preferences not initialized');
      return;
    }
    try {
      await this.preferences.delete(SEARCH_HISTORY_KEY);
      await this.preferences.flush();
    } catch (err) {
      console.error('SearchHistoryManager: Failed to clear search history, error: ' + err);
    }
  }
}

export const searchHistoryManager = new SearchHistoryManager();
